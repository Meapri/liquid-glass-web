{
  "name": "liquid-glass",
  "version": "0.1.0",
  "type": "module",
  "description": "Apple iOS 26 Liquid Glass engine for the web. GPU + Chromium native.",
  "main": "dist/liquid-glass.js",
  "module": "dist/liquid-glass.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc --noEmit",
    "test:auto-profile": "npm run build:lib && node tests/auto-profile.mjs",
    "test": "npm run typecheck && npm run test:auto-profile"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.0"
  }
}
